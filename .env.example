# MySQL MCP 连接配置
# 复制为 .env 后填入真实密码：cp .env.example .env
# 变量名需与 @benborla29/mcp-server-mysql 一致

MYSQL_HOST=db.wulianxx.com
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASS=your_password_here
MYSQL_DB=tess_yangchen_ms

# 写操作默认关闭；需要时改为 true
ALLOW_INSERT_OPERATION=false
ALLOW_UPDATE_OPERATION=false
ALLOW_DELETE_OPERATION=false
