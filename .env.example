# MySQL MCP 连接配置
# 复制为 .env 后填入真实值：cp .env.example .env
# 变量名需与 @benborla29/mcp-server-mysql 一致

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=typhoon
MYSQL_PASS=change_me
MYSQL_DB=typhoon

# 写操作默认关闭；需要时改为 true
ALLOW_INSERT_OPERATION=false
ALLOW_UPDATE_OPERATION=false
ALLOW_DELETE_OPERATION=false
